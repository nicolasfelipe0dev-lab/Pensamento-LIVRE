# Copie este arquivo para ".env" e preencha com os seus valores reais.
# NUNCA suba o arquivo ".env" (com valores reais) para o GitHub.

# Encontrados em: Supabase > seu projeto > Project Settings > API
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_KEY=coloque-aqui-a-service-role-key

# Senha para acessar a área de "novo artigo" no site
ADMIN_PASSWORD=escolha-uma-senha-forte

# Qualquer string aleatória, usada pelo Flask para proteger a sessão/login
SECRET_KEY=troque-por-uma-string-aleatoria-longa
